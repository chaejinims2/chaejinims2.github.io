// /etc 주요 파일

// /etc/passwd         [user name]:[password placeholder]:[UID]:[GID]:[GECOS]:[Home directory]:[Login shell]
// /etc/shadow         [user name]:[password hash]:[PassWDLastModified,(1970-01-01 기준 일수)]:[최소 변경 일, 0이면 언제든 변경 가능]:[최대 변경일, 이 기간 이후 만료]:[경고기간]:[inactive]:[계정 만료]:[reserved]
//                     패스워드 해시 및 만료 정책 저장 
//                     chage가 수정하는 파일, passwd aging은 여기 저장
// /etc/group          [group name]:[password]:[GID]:[members]
//                     developers:x:1001:cherry,apple

// /etc/gshadow        [group name]:[password]:[admin]:[members]
//                     developers:!:cherry:apple

// /etc/fstab          부팅 시 자동 마운트 설정

// /etc/hosts          IP 와 hostname 매핑, DNS 보다 먼저 조회됨

// /etc/resolv.conf    DNS 서버 설정   nameserver 8.8.8.8

// /etc/inittab        runlevel 설정   id:3:initdefalt

// /etc/crontab        분 시 일 월 요일 사용자 명령    * * * * * root test.sh

// /etc/profile        전체 사용자 login shell
// ~/.bashrc           개인 non-login shell

// passwd apple
// passwd -l apple
// passwd -u apple


